{
  "name": "calcscope",
  "version": "0.1.0",
  "private": true,
  "description": "CalcScope monorepo for an interactive calculus graphing platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm --workspace apps/client run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "build:client": "npm --workspace apps/client run build",
    "build:server": "npm --workspace apps/server run build",
    "typecheck": "npm --workspaces run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
